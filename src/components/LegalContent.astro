---
interface Section {
  heading: string;
  paragraphs?: string[];
  list?: string[];
}

interface Props {
  title: string;
  updated: string;
  intro?: string;
  sections: Section[];
}

const { title, updated, intro, sections } = Astro.props;
---

<article class="mx-auto max-w-3xl px-6 py-20 sm:py-24">
  <p class="text-caption font-semibold uppercase tracking-wide text-ef-gray">Legal</p>
  <h1 class="mt-4 text-display-md text-ef-white">{title}</h1>
  <p class="mt-3 text-caption text-ef-muted">Last updated {updated}</p>

  {intro && <p class="mt-8 text-body-lg text-ef-gray" set:html={intro} />}

  <div class="mt-12 flex flex-col gap-10">
    {
      sections.map((section) => (
        <section>
          <h2 class="text-h2 text-ef-white">{section.heading}</h2>
          {section.paragraphs?.map((p) => (
            <p class="mt-3 text-body text-ef-gray [&_a]:text-ef-green [&_a]:underline [&_a]:underline-offset-2 hover:[&_a]:text-ef-white" set:html={p} />
          ))}
          {section.list && (
            <ul class="mt-3 flex flex-col gap-2">
              {section.list.map((item) => (
                <li class="flex gap-3 text-body text-ef-gray">
                  <span class="mt-0.5 text-ef-green" aria-hidden="true">—</span>
                  <span set:html={item} />
                </li>
              ))}
            </ul>
          )}
        </section>
      ))
    }
  </div>
</article>
