---
import { Image } from "astro:assets";
import logo from "../assets/logo-horizontal.png";

interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<a href="/" class={`inline-flex items-center gap-2 ${className}`} aria-label="Elevation Finance Educational home">
  <Image src={logo} alt="Elevation Finance" height={32} class="w-auto" />
  <span class="hidden text-caption font-medium uppercase tracking-wide text-ef-gray md:inline">Educational</span>
</a>
