---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import LegalContent from "../components/LegalContent.astro";

const sections = [
  {
    heading: "Agreement to Terms",
    paragraphs: [
      `By accessing or using elevation-finance.com (the "Site"), you agree to be bound by these Terms of Service. If you don't agree, please don't use the Site.`,
    ],
  },
  {
    heading: "Educational Content Only",
    paragraphs: [
      `Everything published on the Site is for general informational and educational purposes only. Nothing here constitutes investment, legal, or tax advice, or a recommendation to buy, sell, or hold any security. Always do your own research and consult a licensed professional before making financial decisions.`,
    ],
  },
  {
    heading: "No Warranty",
    paragraphs: [
      `We verify numbers, dates, and sources before publishing, and correct mistakes when we find them. Even so, we make no warranty that any content is complete, current, or error-free. Markets move — data on the Site may be out of date by the time you read it.`,
    ],
  },
  {
    heading: "Intellectual Property",
    paragraphs: [
      `The text, graphics, charts, and branding on the Site are owned by Elevation Finance unless otherwise credited, and may not be reproduced or redistributed without permission.`,
    ],
  },
  {
    heading: "Third-Party Links",
    paragraphs: [
      `The Site links to third-party services, including Facebook and the App Store. We don't control and aren't responsible for the content, accuracy, or practices of any third-party site or service you reach from a link on the Site.`,
    ],
  },
  {
    heading: "Acceptable Use",
    paragraphs: [`Please don't:`],
    list: [
      "Attempt to gain unauthorized access to the Site or its systems.",
      "Scrape or systematically extract content at scale.",
      "Interfere with the normal operation of the Site.",
    ],
  },
  {
    heading: "Limitation of Liability",
    paragraphs: [
      `To the fullest extent permitted by law, Elevation Finance is not liable for any loss or damage arising from your use of, or inability to use, the Site, or from any decision made in reliance on its content.`,
    ],
  },
  {
    heading: "Changes to These Terms",
    paragraphs: [
      `We may revise these Terms at any time. Continuing to use the Site after a change means you accept the updated Terms.`,
    ],
  },
  {
    heading: "Governing Law",
    paragraphs: [
      `These Terms are governed by the laws of the United States, without regard to conflict-of-law principles.`,
    ],
  },
  {
    heading: "Contact",
    paragraphs: [
      `Questions about these Terms can be sent to <a href="mailto:oleg.posyniak@gmail.com">oleg.posyniak@gmail.com</a>.`,
    ],
  },
];
---

<Layout title="Terms of Service — Elevation Finance" description="The terms that govern use of elevation-finance.com.">
  <Header />
  <main>
    <LegalContent title="Terms of Service" updated="July 11, 2026" sections={sections} />
  </main>
  <Footer />
</Layout>
