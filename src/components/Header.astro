---
import Logo from "./Logo.astro";
import Button from "./Button.astro";

const links = [
  { href: "/#approach", label: "Approach" },
  { href: "/#formats", label: "What We Publish" },
  { href: "/#updates", label: "Get Updates" },
  { href: "https://www.facebook.com/elevation.finance", label: "Facebook" },
];
---

<header class="sticky top-0 z-50 border-b border-ef-border bg-ef-background">
  <div class="mx-auto flex h-20 max-w-6xl items-center justify-between px-6">
    <Logo />
    <nav class="hidden items-center gap-8 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="text-body text-ef-gray transition-colors hover:text-ef-white"
          >
            {link.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-3">
      <details class="md:hidden">
        <summary class="flex h-10 w-10 cursor-pointer list-none items-center justify-center rounded-full border border-ef-border text-ef-gray transition-colors hover:text-ef-white [&::-webkit-details-marker]:hidden">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M2 4.5H16M2 9H16M2 13.5H16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span class="sr-only">Open menu</span>
        </summary>
        <nav class="fixed right-6 top-24 z-50 flex w-56 flex-col gap-1 rounded-card border border-ef-border bg-ef-surface p-2 shadow-lg">
          {
            links.map((link) => (
              <a
                href={link.href}
                target={link.href.startsWith("http") ? "_blank" : undefined}
                rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="rounded-lg px-3 py-2 text-body text-ef-gray transition-colors hover:bg-ef-surface-elevated hover:text-ef-white"
              >
                {link.label}
              </a>
            ))
          }
        </nav>
      </details>
      <Button
        href="https://apps.apple.com/us/app/elevation-finance-tools/id6778583335"
        variant="primary"
        class="!px-5 !py-2 text-caption"
      >
        Get the App
      </Button>
    </div>
  </div>

  <script>
    document.querySelectorAll("header details").forEach((details) => {
      details.querySelectorAll("a").forEach((link) => {
        link.addEventListener("click", () => details.removeAttribute("open"));
      });
      document.addEventListener("click", (event) => {
        if (!details.contains(event.target as Node)) {
          details.removeAttribute("open");
        }
      });
    });
  </script>
</header>
